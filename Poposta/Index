<!DOCTYPE html>

<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CUPA Inspira – Elevador</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Syne:wght@700;800&family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
<style>
* { margin:0; padding:0; box-sizing:border-box; }
:root {
  --verde: #1e4d1a;
  --verde2: #3a7d35;
  --lima: #9ed46a;
  --tierra: #c4622d;
  --crema: #f5f0e6;
  --negro: #111;
}
body {
  background: #888;
  display: flex;
  justify-content: center;
  padding: 20px;
  font-family: 'DM Sans', sans-serif;
}
.poster {
  width: 210mm;
  min-height: 297mm;
  background: var(--negro);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  position: relative;
}

/* FOTO HERO */
.hero {
position: relative;
height: 195px;
overflow: hidden;
display: flex;
}
.hero-img {
width: 50%;
object-fit: cover;
object-position: center;
filter: brightness(0.75) saturate(0.9);
}
.hero-overlay {
position: absolute;
inset: 0;
background: linear-gradient(to bottom, transparent 30%, var(–negro) 100%);
}
.hero-badge {
position: absolute;
top: 14px;
left: 14px;
background: var(–tierra);
color: white;
font-family: ‘DM Sans’, sans-serif;
font-size: 10px;
font-weight: 700;
letter-spacing: 2px;
text-transform: uppercase;
padding: 5px 12px;
border-radius: 100px;
}

/* YA EXISTE en BJ */
.existe-tag {
position: absolute;
bottom: 12px;
right: 14px;
background: var(–lima);
color: var(–negro);
font-size: 10px;
font-weight: 700;
letter-spacing: 1px;
text-transform: uppercase;
padding: 4px 10px;
border-radius: 6px;
}

/* MAIN */
.main {
padding: 18px 28px 0;
flex: 1;
display: flex;
flex-direction: column;
}

.kicker {
font-size: 11px;
letter-spacing: 3px;
text-transform: uppercase;
color: var(–lima);
margin-bottom: 8px;
}

.headline {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 76px;
line-height: 0.88;
color: white;
margin-bottom: 16px;
}
.headline .accent { color: var(–lima); }

.claim {
font-size: 15px;
color: rgba(255,255,255,0.75);
line-height: 1.55;
margin-bottom: 22px;
max-width: 90%;
}
.claim strong { color: white; }

/* 3 PUNTOS CLAVE */
.puntos {
display: flex;
flex-direction: column;
gap: 8px;
margin-bottom: 24px;
}
.punto {
display: flex;
align-items: center;
gap: 12px;
}
.punto-num {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 34px;
color: var(–lima);
line-height: 1;
min-width: 30px;
}
.punto-text {
font-size: 14px;
color: rgba(255,255,255,0.85);
line-height: 1.3;
}
.punto-text strong { color: white; display: block; }

/* PROGRESO MINIMALISTA */
.progress-wrap {
background: rgba(255,255,255,0.06);
border-radius: 12px;
padding: 14px 18px;
margin-bottom: 22px;
display: flex;
align-items: center;
gap: 16px;
}
.prog-nums {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 42px;
color: var(–lima);
line-height: 1;
white-space: nowrap;
}
.prog-nums span { font-size: 20px; color: rgba(255,255,255,0.3); }
.prog-right { flex: 1; }
.prog-bar-bg {
background: rgba(255,255,255,0.12);
border-radius: 100px;
height: 8px;
margin-bottom: 6px;
overflow: hidden;
}
.prog-bar-fill {
background: linear-gradient(90deg, var(–verde2), var(–lima));
height: 100%;
width: 20%;
border-radius: 100px;
}
.prog-label { font-size: 12px; color: rgba(255,255,255,0.5); }
.prog-label strong { color: #f4845f; }

/* CTA */
.cta {
background: var(–tierra);
border-radius: 14px;
padding: 20px 22px;
margin-bottom: 0;
display: flex;
align-items: center;
gap: 16px;
}
.cta-arrow {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 52px;
color: white;
line-height: 1;
opacity: 0.6;
}
.cta-right {}
.cta-top {
font-size: 11px;
letter-spacing: 2px;
text-transform: uppercase;
color: rgba(255,255,255,0.65);
margin-bottom: 4px;
}
.cta-action {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 32px;
color: white;
line-height: 1;
margin-bottom: 6px;
}
.cta-where {
font-size: 12px;
color: rgba(255,255,255,0.8);
font-weight: 700;
}

/* FOOTER */
.footer {
background: var(–verde);
padding: 12px 28px;
display: flex;
align-items: center;
justify-content: space-between;
margin-top: auto;
}
.footer-org {
font-size: 10px;
color: rgba(255,255,255,0.5);
letter-spacing: 1px;
text-transform: uppercase;
}
.footer-brand {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 22px;
color: var(–lima);
letter-spacing: 2px;
}

@media print {
body { background: none; padding: 0; }
}
</style>

</head>
